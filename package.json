{
  "name": "innoaivators-billing",
  "version": "1.0.0",
  "main": "backend/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run start\"",
    "dev:frontend": "cd Frontend && npm run dev",
    "build:frontend": "cd Frontend && npm run build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:win": "npm run build:frontend && electron-builder --win",
    "build:mac": "npm run build:frontend && electron-builder --mac",
    "build:linux": "npm run build:frontend && electron-builder --linux",
    "build:all": "npm run build:frontend && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.smart.billing",
    "productName": "Innoaivators Billing System",
    "copyright": "Copyright © 2026 AjithXDev",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "backend/**/*",
      "Frontend/dist/**/*",
      "mobile-dashboard/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Innoaivators Billing System"
    }
  },
  "keywords": [],
  "author": "AjithXDev",
  "license": "ISC",
  "description": "Smart Billing Desktop Application - Professional Retail & Billing Solution",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.103.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "localtunnel": "^2.0.2",
    "nodemailer": "^8.0.5",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "github:pedroslopez/whatsapp-web.js#main"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "concurrently": "^9.1.2",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.2"
  }
}
